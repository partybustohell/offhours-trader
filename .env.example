# Claude API — used by analyst, synthesizer, and executor agents
ANTHROPIC_API_KEY=

# Alpaca DEMO (paper) account — default. Get keys at https://app.alpaca.markets
# after creating a paper account. These are the only broker keys the system
# uses in paper and dry-run modes.
ALPACA_PAPER_KEY=
ALPACA_PAPER_SECRET=

# Alpaca LIVE account — leave unset until you deliberately connect a real
# account. Live mode additionally requires mode: live AND
# live_trading_acknowledged: true in config.yaml. Paper keys are never used
# for live, and live keys are never used for paper.
# ALPACA_LIVE_KEY=
# ALPACA_LIVE_SECRET=
